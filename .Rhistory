boot_mic_adjust <- function(split, x = "x", y = "y", tr = "trat", model = model){
dat <- analysis(split)
reliability <- tr_reliability(dat, model = model, modification = FALSE)
tibble(
term = "mic_roc",
estimate = mic_adjust(data = dat, x = x, y = y, tr = tr, reliability = reliability),
std.err = NA_real_)
}
