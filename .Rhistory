mutate(mic_roc = map(splits, boot_mic_roc),
mic_pred = map(splits, boot_mic_pred))
int_pctl(boot_mics, mic_pred, alpha = 0.05)
int_pctl(boot_mics, mic_roc, alpha = 0.05)
